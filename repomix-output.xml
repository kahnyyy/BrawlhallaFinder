<file path="src/App.css">
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg: #07070e;
  --panel: #0f0f1c;
  --card: #141425;
  --border: #25253a;
  --border-bright: #3a3a60;
  --accent: #f5c842;
  --accent2: #e8693d;
  --accent-glow: rgba(245,200,66,0.18);
  --text: #e8e8f5;
  --muted: #606090;
  --radius: 14px;
}

body {
  background: var(--bg);
  color: var(--text);
  font-family: 'Barlow', sans-serif;
  min-height: 100vh;
  overflow-x: hidden;
}

.app { position: relative; min-height: 100vh; }

.bg-grid {
  position: fixed; inset: 0;
  background-image:
    linear-gradient(rgba(245,200,66,0.025) 1px, transparent 1px),
    linear-gradient(90deg, rgba(245,200,66,0.025) 1px, transparent 1px);
  background-size: 56px 56px;
  pointer-events: none; z-index: 0;
}
.blob { position: fixed; border-radius: 50%; filter: blur(80px); pointer-events: none; z-index: 0; }
.blob-1 { width: 500px; height: 500px; background: rgba(245,200,66,0.04); top: -100px; left: -100px; }
.blob-2 { width: 400px; height: 400px; background: rgba(232,105,61,0.05); bottom: 100px; right: -80px; }

/* ── HEADER ── */
header {
  position: relative; z-index: 1;
  text-align: center; padding: 56px 24px 40px;
}
.eyebrow {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 12px; font-weight: 700; letter-spacing: 8px;
  color: var(--accent); margin-bottom: 12px; opacity: 0.85;
}
h1 {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(64px, 14vw, 120px);
  line-height: 0.88; letter-spacing: 3px;
  background: linear-gradient(140deg, #ffffff 0%, var(--accent) 55%, var(--accent2) 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  margin-bottom: 16px;
}
.tagline {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 15px; letter-spacing: 3px; text-transform: uppercase; color: var(--muted);
}

/* ── MAIN ── */
main {
  position: relative; z-index: 1;
  max-width: 960px; margin: 0 auto; padding: 40px 20px 100px;
}

/* ── SELECTION ROW ── */
.sel-row {
  display: flex; align-items: center; justify-content: center;
  gap: 12px; flex-wrap: wrap; margin-bottom: 36px;
}
.sel-empty {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 14px; letter-spacing: 2px; text-transform: uppercase;
  color: var(--muted); border: 1px dashed var(--border-bright);
  border-radius: 50px; padding: 9px 26px; min-width: 120px; text-align: center;
}
.sel-pill {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 14px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase;
  color: var(--accent); border: 1.5px solid var(--accent); background: rgba(245,200,66,0.08);
  border-radius: 50px; padding: 8px 18px; cursor: pointer;
  display: flex; align-items: center; gap: 10px;
  transition: background 0.15s, transform 0.12s;
}
.sel-pill:hover { background: rgba(245,200,66,0.16); transform: translateY(-1px); }
.pill-content { display: flex; align-items: center; gap: 8px; }
.pill-remove { opacity: 0.5; font-size: 11px; margin-left: 4px; }
.sel-plus { font-size: 22px; color: var(--muted); font-weight: 200; }

/* Weapon images in pills */
img.pill-weapon-img { width: 20px; height: 20px; object-fit: contain; border-radius: 3px; flex-shrink: 0; }
span.pill-weapon-img { font-size: 16px; line-height: 1; flex-shrink: 0; }

/* Share button */
.share-btn {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 13px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase;
  color: var(--muted); border: 1px solid var(--border-bright);
  background: transparent; border-radius: 50px; padding: 8px 18px; cursor: pointer;
  transition: all 0.15s;
}
.share-btn:hover { border-color: var(--accent); color: var(--accent); }

/* ── SIMILAR BANNER ── */
.similar-banner {
  display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 10px;
  background: rgba(245,200,66,0.07); border: 1px solid rgba(245,200,66,0.25);
  border-radius: 10px; padding: 12px 18px; margin-bottom: 24px;
  font-family: 'Barlow Condensed', sans-serif; font-size: 15px; letter-spacing: 1px; color: var(--text);
}
.similar-banner strong { color: var(--accent); }
.similar-banner button {
  background: transparent; border: none; color: var(--muted);
  cursor: pointer; font-size: 13px; padding: 2px 8px; transition: color 0.15s;
}
.similar-banner button:hover { color: var(--accent2); }

/* ── PICKER PANEL ── */
.picker-panel {
  background: var(--panel); border: 1px solid var(--border);
  border-radius: var(--radius); padding: 24px 24px 28px;
  margin-bottom: 40px; position: relative; overflow: hidden;
}
.picker-panel::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
  background: linear-gradient(90deg, var(--accent2), var(--accent), var(--accent2)); opacity: 0.7;
}
.picker-top {
  display: flex; align-items: center; justify-content: space-between;
  flex-wrap: wrap; gap: 12px; margin-bottom: 20px;
}
.picker-heading {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 20px; letter-spacing: 3px; color: var(--text);
  display: flex; align-items: center; gap: 12px;
}
.step-num {
  font-size: 13px; font-family: 'Barlow Condensed', sans-serif;
  font-weight: 700; letter-spacing: 1px; color: var(--accent);
  border: 1px solid var(--accent); border-radius: 4px; padding: 2px 7px;
}
.step-num.done { background: rgba(245,200,66,0.15); }

/* Category tabs */
.cat-tabs { display: flex; gap: 6px; flex-wrap: wrap; }
.cat-tab {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 12px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase;
  color: var(--muted); background: var(--card); border: 1px solid var(--border);
  border-radius: 6px; padding: 5px 12px; cursor: pointer; transition: all 0.15s;
}
.cat-tab:hover { border-color: var(--border-bright); color: var(--text); }
.cat-tab.active { border-color: var(--accent); color: var(--accent); background: rgba(245,200,66,0.08); }

/* Weapon grid */
.weapon-grid {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(118px, 1fr)); gap: 10px;
}
.weapon-btn {
  background: var(--card); border: 1px solid var(--border); border-radius: 10px;
  padding: 12px 8px 10px; cursor: pointer;
  display: flex; flex-direction: column; align-items: center; gap: 5px;
  color: var(--text); font-family: 'Barlow Condensed', sans-serif;
  transition: all 0.16s ease; position: relative; overflow: hidden;
}
.weapon-btn:hover:not(:disabled) {
  border-color: var(--border-bright); background: rgba(255,255,255,0.04); transform: translateY(-2px);
}
.weapon-btn.selected {
  border-color: var(--accent); background: rgba(245,200,66,0.1); color: var(--accent);
  box-shadow: 0 0 20px rgba(245,200,66,0.15), inset 0 0 12px rgba(245,200,66,0.05);
}
.weapon-btn.selected::after {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: var(--accent);
}
.weapon-btn.dimmed { opacity: 0.22; cursor: not-allowed; }
.weapon-img { display: block; width: 34px; height: 34px; object-fit: contain; border-radius: 4px; }
.weapon-emoji { font-size: 24px; line-height: 1; display: block; }
.btn-weapon-img { width: 34px; height: 34px; }
.w-label { font-size: 11px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; text-align: center; line-height: 1.2; }
.w-cat { font-size: 9px; letter-spacing: 1px; text-transform: uppercase; color: var(--muted); margin-top: 1px; }
.w-check { position: absolute; top: 5px; right: 7px; font-size: 10px; color: var(--accent); opacity: 0.7; }

/* ── SEARCH ── */
.search-wrap {
  position: relative; margin-bottom: 24px;
}
.search-input {
  width: 100%; background: var(--card); border: 1px solid var(--border-bright);
  border-radius: 10px; padding: 11px 40px 11px 16px;
  color: var(--text); font-family: 'Barlow', sans-serif; font-size: 15px;
  outline: none; transition: border-color 0.15s;
}
.search-input::placeholder { color: var(--muted); }
.search-input:focus { border-color: var(--accent); }
.search-clear {
  position: absolute; right: 12px; top: 50%; transform: translateY(-50%);
  background: none; border: none; color: var(--muted); cursor: pointer;
  font-size: 14px; padding: 4px; transition: color 0.15s;
}
.search-clear:hover { color: var(--accent2); }

/* ── RESULTS ── */
.results { animation: fadeIn 0.3s ease; }
@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

.reset-btn {
  display: block; margin: 0 auto 28px;
  background: transparent; border: 1px solid var(--border-bright);
  border-radius: 8px; color: var(--muted);
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 13px; letter-spacing: 2px; text-transform: uppercase;
  padding: 8px 22px; cursor: pointer; transition: all 0.15s;
}
.reset-btn:hover { border-color: var(--accent2); color: var(--accent2); }

.results-meta {
  display: flex; align-items: baseline; gap: 16px; margin-bottom: 20px; flex-wrap: wrap;
}
.results-title {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 28px; letter-spacing: 3px; color: var(--accent); line-height: 1;
}
.results-title span { color: var(--accent); }
.results-title .dim { color: var(--muted); margin: 0 4px; }
.count {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 13px; letter-spacing: 2px; color: var(--muted); text-transform: uppercase;
  border: 1px solid var(--border); border-radius: 20px; padding: 3px 12px;
}

/* ── LEGEND CARDS ── */
.results-grid {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(178px, 1fr)); gap: 14px;
}
.legend-card {
  background: var(--card); border: 1px solid var(--border); border-radius: var(--radius);
  transition: all 0.2s ease; animation: slideUp 0.35s ease both;
  position: relative; overflow: hidden;
}
.legend-card:hover { border-color: var(--border-bright); }
.legend-card.expanded { border-color: var(--accent); box-shadow: 0 0 24px var(--accent-glow); }

@keyframes slideUp {
  from { opacity: 0; transform: translateY(18px); }
  to   { opacity: 1; transform: translateY(0); }
}

.card-main {
  padding: 20px 14px 16px; display: flex; flex-direction: column; align-items: center; gap: 10px;
  cursor: pointer; transition: background 0.15s;
}
.card-main:hover { background: rgba(255,255,255,0.02); }

.legend-avatar {
  width: 70px; height: 70px; border-radius: 50%;
  background: var(--panel); border: 2px solid var(--border-bright);
  display: flex; align-items: center; justify-content: center;
  overflow: hidden; transition: border-color 0.2s; flex-shrink: 0;
}
.legend-card.expanded .legend-avatar { border-color: var(--accent); }
.legend-avatar img { width: 100%; height: 100%; object-fit: cover; object-position: top center; }
.avatar-initials { font-family: 'Bebas Neue', sans-serif; font-size: 24px; color: var(--accent); }

.l-name {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 18px; letter-spacing: 2px; text-align: center; color: var(--text);
}

.w-tags { display: flex; flex-wrap: wrap; gap: 5px; justify-content: center; }
.tag {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 10px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase;
  padding: 3px 8px; border-radius: 20px; border: 1px solid var(--border);
  color: var(--muted); white-space: nowrap;
}
.tag.hl { border-color: var(--accent); color: var(--accent); background: rgba(245,200,66,0.1); }

.expand-hint {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 10px; letter-spacing: 1px; text-transform: uppercase;
  color: var(--muted); margin-top: 2px;
}

/* ── STAT BARS ── */
.card-stats {
  border-top: 1px solid var(--border); padding: 14px 14px 12px;
  display: flex; flex-direction: column; gap: 7px;
}
.stat-row {
  display: flex; align-items: center; gap: 8px;
}
.stat-label {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 10px; font-weight: 700; letter-spacing: 1px;
  color: var(--muted); width: 26px; flex-shrink: 0;
}
.stat-track {
  flex: 1; height: 5px; background: var(--border); border-radius: 3px; overflow: hidden;
}
.stat-fill { height: 100%; border-radius: 3px; transition: width 0.4s ease; }
.stat-val {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 13px; color: var(--text); width: 14px; text-align: right; flex-shrink: 0;
}

/* Card actions */
.card-actions {
  display: flex; gap: 6px; margin-top: 8px; flex-wrap: wrap;
}
.similar-btn, .wiki-link {
  flex: 1; text-align: center; padding: 6px 8px;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 11px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase;
  border-radius: 7px; cursor: pointer; transition: all 0.15s; text-decoration: none;
  white-space: nowrap;
}
.similar-btn {
  background: var(--panel); border: 1px solid var(--border-bright); color: var(--muted);
}
.similar-btn:hover { border-color: var(--accent); color: var(--accent); }
.wiki-link {
  background: var(--panel); border: 1px solid var(--border-bright); color: var(--muted);
  display: flex; align-items: center; justify-content: center; gap: 4px;
}
.wiki-link:hover { border-color: var(--accent2); color: var(--accent2); }

/* ── NO RESULTS ── */
.no-results {
  padding: 40px 20px; text-align: center;
}
.no-main {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 18px; letter-spacing: 3px; text-transform: uppercase;
  color: var(--muted); margin-bottom: 28px;
}
.no-fallback {
  display: flex; gap: 20px; flex-wrap: wrap; justify-content: center;
}
.no-fallback-group {
  background: var(--card); border: 1px solid var(--border);
  border-radius: 12px; padding: 16px 20px; text-align: left; max-width: 300px;
}
.no-fallback-label {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 14px; letter-spacing: 1px; color: var(--muted); margin-bottom: 10px;
}
.no-fallback-label strong { color: var(--accent); }
.no-fallback-names { display: flex; flex-wrap: wrap; gap: 5px; }
.no-name {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 12px; font-weight: 700; letter-spacing: 1px;
  color: var(--text); background: var(--panel); border: 1px solid var(--border);
  border-radius: 6px; padding: 3px 9px;
}

/* ── MISC ── */
.start-hint {
  text-align: center; margin-top: 8px;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 14px; letter-spacing: 2px; text-transform: uppercase; color: var(--muted);
}

@media (max-width: 480px) {
  .weapon-grid { grid-template-columns: repeat(auto-fill, minmax(100px, 1fr)); }
  .results-grid { grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); }
  .picker-top { flex-direction: column; align-items: flex-start; }
}
